# Email para notificaciones del sistema
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_USER="tu@email.com"
EMAIL_PASS="tu-password"
EMAIL_FROM="Cirochat <noreply@tudominio.com>"
