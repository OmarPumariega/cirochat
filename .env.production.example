# ============================================================
# CIROCHAT — Variables de entorno de PRODUCCIÓN
# Uso en el VPS:
#   1) cp .env.production.example .env.production
#   2) rellena los valores reales (NO subas este archivo a git)
#
# Genera los secretos en el VPS con:
#   openssl rand -base64 32     -> NEXTAUTH_SECRET
#   openssl rand -hex 16        -> ENCRYPTION_KEY  (32 hex chars)
# ============================================================

# --- Base de datos (credenciales del contenedor postgres) ---
# El usuario/contraseña/nombre que se crearán al arrancar el contenedor "db".
# La URL real se construye en docker-compose.yml apuntando a "db".
POSTGRES_USER=cirochat
POSTGRES_PASSWORD=CAMBIA_POR_UNA_CONTRASENA_FUENTE
POSTGRES_DB=cirochat

# --- NextAuth ---
NEXTAUTH_SECRET=PEGA_AQUI_EL_RESULTADO_DE_openssl_rand_base64_32
NEXTAUTH_URL=https://cirochat.agenciaciro.com

# --- Encriptación AES-256 de las API keys de clientes ---
# EXACTAMENTE 32 caracteres -> openssl rand -hex 16
ENCRYPTION_KEY=PEGA_AQUI_32_CARACTERES_HEX

# --- Email (opcional, notificaciones de leads) ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=Cirochat <noreply@agenciaciro.com>
